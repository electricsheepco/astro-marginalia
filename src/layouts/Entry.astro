---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import EntrySources from '../components/EntrySources.astro';
import LayerTimeline from '../components/LayerTimeline.astro';

interface Props {
  entry: CollectionEntry<'entries'>;
}

const { entry } = Astro.props;
const { concept, concept_tamil, thematic_cluster, status, layers, related, editorial_note, image } = entry.data;
const canonicalHeroFiles = import.meta.glob('/public/heroes/*.{png,jpg,jpeg,webp,svg}', { eager: true });
const canonicalHeroSrc = `/heroes/${entry.slug}.png`;
const canonicalHeroImage = Object.hasOwn(canonicalHeroFiles, `/public${canonicalHeroSrc}`) ? canonicalHeroSrc : undefined;
const heroImage = image || (canonicalHeroImage
  ? {
      src: canonicalHeroImage,
      alt: `Hero image for ${concept_tamil}`,
      credit: undefined,
      credit_url: undefined,
    }
  : undefined);
const allEntries = await getCollection('entries');
const entrySlugs = new Set<string>(allEntries.map((item) => item.slug));
const shareTransliteration = layers.proto_tamil?.transliteration || layers.modern.colloquial;
const shareText = `${concept_tamil} (${shareTransliteration}) — ${concept} | Astro Marginalia`;
const shareUrl = `https://example.com/entries/${entry.slug}`;
const encodedShareText = encodeURIComponent(shareText);
const encodedShareUrl = encodeURIComponent(shareUrl);
const encodedWhatsAppText = encodeURIComponent(`${shareText} ${shareUrl}`);
const layerNavItems = [
  layers.proto_tamil && {
    href: '#layer-proto',
    label: 'Proto',
    word: layers.proto_tamil.word,
  },
  layers.classical && {
    href: '#layer-classical',
    label: 'Classical',
    word: layers.classical.word,
  },
  layers.sanskrit_influenced && {
    href: '#layer-sanskrit',
    label: layers.sanskrit_influenced.label || 'Contact',
    word: layers.sanskrit_influenced.word,
  },
  layers.other_language && {
    href: '#layer-other',
    label: layers.other_language.source_language,
    word: layers.other_language.word,
  },
  {
    href: '#layer-modern',
    label: 'Modern',
    word: layers.modern.literary || layers.modern.colloquial,
  },
].filter(Boolean) as Array<{ href: string; label: string; word: string }>;
const entryTocItems = [
  editorial_note ? { href: '#entry-marginalia', label: 'Marginalia' } : undefined,
  { href: '#entry-prose', label: 'Essay' },
  { href: '#entry-journey', label: 'Journey' },
  related && related.length > 0 ? { href: '#entry-related', label: 'Related' } : undefined,
  { href: '#entry-sources', label: 'Sources' },
].filter(Boolean) as Array<{ href: string; label: string }>;
---

<Base title={`${concept_tamil} — ${concept}`} description={editorial_note} ogType="article" ogImage={heroImage?.src}>
  <article class="entry-page">
    <header class="entry-hero">
      <div class="container-wide entry-hero-grid">
        <div class="entry-hero-main">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">/</span>
            <a href={`/cluster/${thematic_cluster}`}>{thematic_cluster}</a>
            <span aria-hidden="true">/</span>
            <span>{concept}</span>
          </nav>
          <div class="entry-meta-row">
            <a href={`/cluster/${thematic_cluster}`} class="cluster-tag">{thematic_cluster}</a>
            <span class={`status-badge status-badge--${status}`}>{status}</span>
          </div>
          <h1 class="entry-word">{concept_tamil}</h1>
          <div class="transliteration">
            {layers.proto_tamil?.transliteration || layers.modern.colloquial}
          </div>
          <div class="concept-label">{concept}</div>
          <nav class="entry-rail-map" aria-label="Entry layer navigation">
            <div class="entry-rail-map__header">
              <span>Lineage</span>
              <a href="#entry-journey">Journey</a>
            </div>
            <ol>
              {layerNavItems.map((item) => (
                <li>
                  <a href={item.href}>
                    <span>{item.label}</span>
                    <strong>{item.word}</strong>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </div>
        {(heroImage || editorial_note) && (
          <div class="entry-hero-aside">
            {heroImage && (
              <figure class="entry-hero-image">
                <img src={heroImage.src} alt={heroImage.alt} width="600" height="600" />
                {heroImage.credit && (
                  <figcaption>
                    {heroImage.credit_url ? (
                      <a href={heroImage.credit_url} target="_blank" rel="noopener noreferrer">{heroImage.credit}</a>
                    ) : (
                      heroImage.credit
                    )}
                  </figcaption>
                )}
              </figure>
            )}
            <nav class="entry-hero-toc" aria-label="Entry quick links">
              <div class="entry-hero-toc__title">On this page</div>
              <div class="entry-hero-toc__links">
                {entryTocItems.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))}
              </div>
            </nav>
            {editorial_note && (
              <aside class="editorial" id="entry-marginalia" data-pagefind-body>
                {editorial_note}
              </aside>
            )}
          </div>
        )}
      </div>
    </header>

    <nav class="entry-floating-toc" aria-label="Entry table of contents">
      <div class="entry-floating-toc__title">On this page</div>
      <ol>
        {entryTocItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ol>
    </nav>

    <div class="container entry-body">
      <section class="entry-prose" id="entry-prose" data-pagefind-body>
        <slot />
      </section>

      <section
        class="entry-share"
        data-entry-share
        data-share-title={`${concept_tamil} — ${concept}`}
        data-share-text={shareText}
        data-share-url={shareUrl}
      >
        <div class="mono">Share</div>
        <div class="share-actions share-actions--native" hidden>
          <button class="share-button" type="button" data-native-share>
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M6 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M18 6m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M18 18m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M8.7 10.7l6.6 -3.4" />
              <path d="M8.7 13.3l6.6 3.4" />
            </svg>
            Share
          </button>
        </div>
        <div class="share-actions share-actions--desktop">
          <a class="share-button" href={`https://wa.me/?text=${encodedWhatsAppText}`} target="_blank" rel="noopener noreferrer">
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 3.2l-5.05 .6" />
              <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" />
            </svg>
            WhatsApp
          </a>
          <a class="share-button" href={`https://twitter.com/intent/tweet?text=${encodedShareText}&url=${encodedShareUrl}`} target="_blank" rel="noopener noreferrer">
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
              <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
            </svg>
            X
          </a>
          <a class="share-button" href={`https://www.facebook.com/sharer/sharer.php?u=${encodedShareUrl}`} target="_blank" rel="noopener noreferrer">
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3" />
            </svg>
            Facebook
          </a>
          <a class="share-button" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedShareUrl}`} target="_blank" rel="noopener noreferrer">
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M8 11v5" />
              <path d="M8 8v.01" />
              <path d="M12 16v-5" />
              <path d="M16 16v-3a2 2 0 0 0 -4 0" />
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
            </svg>
            LinkedIn
          </a>
          <a class="share-button" href={`/entries/${entry.slug}/share`}>
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z" />
              <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M16.5 7.5l.01 0" />
            </svg>
            Instagram
          </a>
          <button class="share-button" type="button" data-copy-link>
            <svg class="share-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M9 15l6 -6" />
              <path d="M11 6l.463 -.536a5 5 0 0 1 7.071 7.072l-.534 .464" />
              <path d="M13 18l-.397 .534a5.068 5.068 0 0 1 -7.127 0a4.972 4.972 0 0 1 0 -7.071l.524 -.463" />
            </svg>
            <span data-copy-label>Copy link</span>
          </button>
        </div>
      </section>

      <section class="entry-evidence" id="entry-journey">
        <div class="journey-heading">
          <div class="mono">The journey</div>
          <div class="journey-rule"></div>
        </div>
        <LayerTimeline layers={layers} />
      </section>

      {related && related.length > 0 && (
        <section class="related-panel" id="entry-related">
          <div class="mono">Related</div>
          <div class="related-links">
          {related.map((r: string) => entrySlugs.has(r) ? (
            <a href={`/entries/${r}`} class="cluster-tag">{r}</a>
          ) : (
            <span class="related-missing">
              {r}
              <span>(not yet written)</span>
            </span>
          ))}
          </div>
        </section>
      )}

      <EntrySources sources={entry.data.sources} unverifiedClaims={entry.data.unverified_claims} />
    </div>
  </article>

  <script>
    const sharePanels = document.querySelectorAll<HTMLElement>('[data-entry-share]');

    sharePanels.forEach((panel) => {
      const title = panel.dataset.shareTitle || document.title;
      const text = panel.dataset.shareText || document.title;
      const url = panel.dataset.shareUrl || window.location.href;
      const nativeActions = panel.querySelector<HTMLElement>('.share-actions--native');
      const desktopActions = panel.querySelector<HTMLElement>('.share-actions--desktop');
      const nativeButton = panel.querySelector<HTMLButtonElement>('[data-native-share]');
      const copyButton = panel.querySelector<HTMLButtonElement>('[data-copy-link]');
      const copyLabel = panel.querySelector<HTMLElement>('[data-copy-label]');
      const canNativeShare = typeof navigator !== 'undefined'
        && typeof navigator.share === 'function'
        && window.matchMedia('(pointer: coarse)').matches;

      if (canNativeShare && nativeActions && desktopActions) {
        nativeActions.hidden = false;
        desktopActions.hidden = true;
      }

      nativeButton?.addEventListener('click', async () => {
        try {
          await navigator.share({ title, text, url });
        } catch {
          // User cancellation should not alter the page state.
        }
      });

      copyButton?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url);
          if (copyLabel) {
            copyLabel.textContent = 'Copied';
            window.setTimeout(() => {
              copyLabel.textContent = 'Copy link';
            }, 1600);
          }
        } catch {
          if (copyLabel) copyLabel.textContent = 'Copy failed';
        }
      });
    });
  </script>
</Base>
