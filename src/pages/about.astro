---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'about');
if (!page) throw new Error('Missing about page content.');

const { Content } = await page.render();
---

<Base title={`${page.data.title || 'About'} — Astro Marginalia`} description={page.data.description}>
  <article class="static-page">
    <div class="container">
      <section class="entry-prose static-page__prose" data-pagefind-body>
        <Content />
      </section>
    </div>
  </article>
</Base>
